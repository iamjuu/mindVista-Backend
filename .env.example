# Email Configuration
EMAIL_PASS=your_email_password
EMAIL_USER=your_email@gmail.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database

# Razorpay Payment Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Server Configuration
PORT=3000
SIGNALING_PORT=8080

# Patient login (JWT). Set a long random string in production.
# JWT_SECRET=your-secret-key

# CORS Origins (comma-separated)
# For local development:
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# For production:
# CORS_ORIGINS=https://your-frontend-domain.vercel.app

# Frontend URL
# For local development:
FRONTEND_URL=http://localhost:5173
# For production:
# FRONTEND_URL=https://your-frontend-domain.vercel.app

# Backend URL
# For local development:
BACKEND_URL=http://localhost:3000
# For production:
# BACKEND_URL=https://your-backend-domain.vercel.app

# WebSocket Signaling Server URL
# For local development:
SIGNALING_SERVER_URL=ws://localhost:8080/signaling
# For production:
# SIGNALING_SERVER_URL=wss://your-backend-domain.vercel.app/signaling

# SMS Provider Configuration (Choose one or more)

# Option 1: Twilio (International SMS & WhatsApp)
# Sign up at: https://www.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+14155238886

# Option 2: MSG91 (Popular in India)
# Sign up at: https://msg91.com/
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=your_sender_id

# Option 3: Fast2SMS (Popular in India)
# Sign up at: https://www.fast2sms.com/
FAST2SMS_API_KEY=your_fast2sms_api_key
FAST2SMS_SENDER_ID=TXTIND

# Note: You only need to configure ONE SMS provider
# The system will automatically use whichever provider is configured
